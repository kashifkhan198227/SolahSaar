rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Matchmaking tickets: readable by any signed-in device (needed to search
    // for a waiting opponent), but only the ticket owner can create/delete
    // their own. Update is left open to any signed-in user because claiming
    // someone else's ticket (setting status + gameId) is how matchmaking pairs
    // two strangers without a server.
    match /matchmakingQueue/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Games: creator must name themselves as host on a fresh waiting room.
    // Readable while still open (so a room code or public listing can be
    // looked up before joining) or by either seated participant afterward.
    // Updatable by either participant, or by someone claiming the open guest
    // seat on a still-waiting room.
    match /games/{gameId} {
      allow create: if request.auth != null
        && request.resource.data.hostUid == request.auth.uid
        && request.resource.data.status == 'waiting';

      allow read: if request.auth != null
        && (resource.data.status == 'waiting'
            || request.auth.uid == resource.data.hostUid
            || request.auth.uid == resource.data.guestUid);

      allow update: if request.auth != null
        && (
          (resource.data.guestUid == null
            && request.resource.data.guestUid == request.auth.uid
            && resource.data.status == 'waiting')
          || request.auth.uid == resource.data.hostUid
          || request.auth.uid == resource.data.guestUid
        );

      allow delete: if false;
    }
  }
}
