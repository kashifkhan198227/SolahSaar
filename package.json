{
  "name": "solahsaar",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~54.0.0",
    "expo-build-properties": "~1.0.10",
    "expo-status-bar": "~3.0.9",
    "firebase": "^12.16.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.2",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.11",
    "jest": "^29.7.0",
    "sharp": "^0.35.3",
    "ts-jest": "^29.2.5",
    "typescript": "~5.9.2"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "generate-icons": "node scripts/generate-icons.js",
    "build:local": "eas build --local --platform android --profile production",
    "submit:local": "eas submit --platform android",
    "build:android": "npx expo prebuild --platform android --clean && cd android && gradlew.bat bundleRelease",
    "build:apk": "npx expo prebuild --platform android --clean && cd android && gradlew.bat assembleRelease"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ]
  },
  "private": true
}
